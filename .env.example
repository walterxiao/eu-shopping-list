# Default to mock mode so a fresh clone never accidentally hits retailers.
# Set to "0" to enable live Playwright scraping (you are responsible for
# complying with each retailer's Terms of Service — see README).
SCRAPE_MOCK=1

# Price cache TTL in seconds (default 1 hour).
CACHE_TTL_SECONDS=3600

# Path to the SQLite cache file.
CACHE_DB_PATH=data/cache.sqlite
